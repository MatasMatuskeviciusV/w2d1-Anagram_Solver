{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Dictionary": {
    "WordFilePath": "Data/zodynas.txt"
  },
  "Settings": {
    "MaxResults": 50,
    "MaxWordsInAnagram": 2,
    "MinUserWordLength": 3
  },
  "ConnectionStrings": {
	"AnagramDb": "Server=.;Database=AnagramSolver_CF;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "OpenAI": {
    "Model": "gpt-5.2",
    "ApiKey": ""
  },
  "Analysis": {
    "StopWords": [ "the", "a", "an", "and", "or", "is", "are" ]
  }
}
